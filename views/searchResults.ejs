<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Habibi Restaurant — Search Results</title>



</head>

<body>

<%
const pool=[
'1565299624946-b28f40a0ae38',
'1568901346375-23c9450c58cd',
'1604382354936-07c5d9983bd3',
'1565958011703-44f9829ba187',
'1606756790138-261d2b21cd75',
'1603133872878-684f208fb84b',
'1512621776951-a57141f2eefd',
'1576107232684-1279f390859f',
'1551183053-bf91a1d81141',
'1455619452474-d2be8b1e70cd',
'1565555326816-e6b00bdd4c0f',
'1547592166-23ac45744acd',
'1546069901-ba9599a7e63c',
'1559847844-5315695dadae',
'1581873372796-635b67ca2008',
'1626700051175-6818013e1d4f',
'1473093295043-cdd812d0e601',
'1631452180519-c014fe946bc7'
];

const img=(n)=>{
let h=0;
for(const c of n)
h=(h*31+c.charCodeAt(0))>>>0;

return `https://images.unsplash.com/photo-${pool[h%pool.length]}?w=300&h=200&fit=crop&q=60`;
}
%>

<span class="eyebrow">LB Kitchen & Grill</span>

<h1>Search Results</h1>

<% if(items.length===0){ %>

<p class="empty">No items found.</p>

<% } else { %>

<div class="grid">

<% items.forEach((item)=>{ %>

<div class="card">

<div class="thumb">

</div>

<div class="body">

<span class="cat">
<%= item.category %>
</span>

<div class="name">
<%= item.foodName %>
</div>

<div class="row">
<span class="price">$<%= item.price %></span>
<span><%= item.quantity %> left</span>
</div>

<div class="row">
<span class="stars">★ <%= item.rating %></span>
</div>

</div>

</div>

<% }) %>

</div>

<% } %>

<a class="back" href="/">← Back Home</a>

</body>
</html>